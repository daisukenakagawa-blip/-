# Googleスプレッドシートを蓄積先にするための認証情報（雛形）
# -------------------------------------------------------------------
# 使い方:
#  - Streamlit Cloud: アプリの Settings → Secrets に、この内容を
#    実際の値に置き換えて貼り付ける（ファイルを置く必要はない）
#  - ローカルで使う場合: このファイルを secrets.toml にコピーして値を入れる
#    （secrets.toml は .gitignore 済み。絶対にコミットしないこと）
#
# 値は、Google Cloud で作成したサービスアカウントのJSONキーの中身です。

[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "xxxxxxxxxxxxxxxxxxxx"
# private_key は改行を \n のままで貼り付ける（前後のダブルクオート必須）
private_key = "-----BEGIN PRIVATE KEY-----\nMIIE...省略...==\n-----END PRIVATE KEY-----\n"
client_email = "your-sa@your-project-id.iam.gserviceaccount.com"
client_id = "000000000000000000000"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"

[gsheet]
# 蓄積先シートのキー（URLの /d/<ここ>/edit の部分）。最も確実な指定方法。
spreadsheet_key = "your-spreadsheet-key"
# ワークシート（タブ）名
worksheet_name = "data"
