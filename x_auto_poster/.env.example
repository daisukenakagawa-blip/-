# ===== X (Twitter) API 認証 =====
# https://developer.x.com/ でアプリを作成し、User authentication settings で
# 「Read and write」権限にしてからキーを発行してください。
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ===== 投稿文の生成 (Claude API) =====
# 未設定でも動作する(テンプレート文にフォールバック)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8
# 発信アカウントのテイスト(プロンプトに渡す前提)
POST_PERSONA=パチスロ・ジャグラー予想系の情報を発信するアカウント
# 本文の文字数上限(全角換算の目安)
MAX_TWEET_CHARS=130

# ===== テーマの取り込み(スマホ運用・任意) =====
# Google スプレッドシートを「ウェブに公開 (CSV)」した URL。
# 設定すると実行のたびにシートの新しいテーマを自動で取り込む。
TOPICS_SHEET_URL=

# ===== 投稿の動作 =====
# 1回の実行で投稿する本数
POSTS_PER_RUN=1
# 画像を添付するか (1=添付する / 0=テキストのみ)
ATTACH_IMAGE=1
# テーマを使い切ったら履歴をリセットして使い回すか (1=する)
RECYCLE_TOPICS=1
# 投稿せず生成内容のプレビューだけ行う (1=プレビューのみ)
DRY_RUN=0
TIMEZONE=Asia/Tokyo
