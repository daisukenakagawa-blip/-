# このファイルを .env という名前でコピーして値を設定してください(任意)。

# ── AIで本文を執筆する場合のみ ───────────────────────────────
# 未設定でも、売れる構成の雛形は出力されます。
ANTHROPIC_API_KEY=

# ── LINE通知(記事ができたらLINEに通知) ─────────────────────
# LINE公式アカウント(Messaging API)のチャネルアクセストークン。
# 取得方法は README の「LINE通知の設定」を参照。
# 設定すると、生成完了時に自分のLINEへ通知が届きます(未設定ならスキップ)。
LINE_CHANNEL_ACCESS_TOKEN=
# 任意。特定の人だけに送りたい場合のuserID。空ならbroadcast(友だち全員=自分)。
LINE_USER_ID=
