# このツールはパスワードを保存しません(login.py でブラウザに手動ログインし、
# セッションを state/note_session.json に保存する方式)。

# ── LINE通知(投稿が終わったらLINEに通知) ───────────────────
# LINE公式アカウント(Messaging API)のチャネルアクセストークン。
# 取得方法は README の「LINE通知の設定」を参照。未設定ならスキップします。
LINE_CHANNEL_ACCESS_TOKEN=
# 任意。特定の人だけに送る場合のuserID。空ならbroadcast(友だち全員=自分)。
LINE_USER_ID=
