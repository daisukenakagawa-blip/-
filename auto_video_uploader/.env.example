# ===== 台本生成 (Claude API) =====
# 未設定でも動作する(テンプレート台本にフォールバック)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# ===== 音声合成 (TTS) =====
# voicevox: ローカルで VOICEVOX エンジン起動が必要 / gtts: APIキー不要
TTS_ENGINE=gtts
VOICEVOX_URL=http://127.0.0.1:50021
VOICEVOX_SPEAKER=3
GTTS_LANG=ja

# ===== 動画 =====
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
# 日本語フォント (テロップ・サムネイル用)
FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Bold.ttc
FONT_NAME=Noto Sans CJK JP
# BGM (任意。ファイルが存在する場合のみミックスされる)
BGM_PATH=assets/bgm.mp3
BGM_VOLUME=0.12

# ===== YouTube =====
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
YOUTUBE_TOKEN_FILE=token.json
# 24 = エンターテインメント
YOUTUBE_CATEGORY_ID=24
# 即時投稿時の公開設定: public / unlisted / private
PRIVACY_STATUS=public
# 予約投稿の時刻 (topics.csv の date が未来日の場合に使用)
PUBLISH_TIME=19:00
TIMEZONE=Asia/Tokyo
