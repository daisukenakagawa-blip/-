# ===== 台本生成 (Claude API) =====
# 未設定でも動作する(テンプレート台本にフォールバック)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# ===== テーマの取り込み =====
# Google スプレッドシートを「ウェブに公開 (CSV)」した URL。
# 設定すると実行のたびにシートの新しいテーマを自動で取り込む(スマホ運用向け)
TOPICS_SHEET_URL=

# ===== 音声合成 (TTS) =====
# auto: VOICEVOX が起動していれば使い、無ければ gTTS (おすすめ)
# voicevox / gtts で固定も可能
TTS_ENGINE=auto
VOICEVOX_URL=http://127.0.0.1:50021
VOICEVOX_SPEAKER=3
GTTS_LANG=ja

# ===== 背景動画の自動取得 (任意) =====
# https://www.pexels.com/api/ で無料発行。設定すると縦型動画を自動で背景に使う
PEXELS_API_KEY=
BACKGROUND_KEYWORD=casino neon lights

# ===== 動画 =====
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
# 日本語フォント (テロップ・サムネイル用)
FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Bold.ttc
FONT_NAME=Noto Sans CJK JP
# BGM (任意。ファイルが存在する場合のみミックスされる)
BGM_PATH=assets/bgm.mp3
BGM_VOLUME=0.12

# ===== 演出・品質 =====
# ランキング構成モード (1=有効 / 0=従来の台本構成)
RANKING_MODE=1
# 効果音の音量 (assets/se.mp3 を置けば差し替え可能)
SE_VOLUME=0.45
# 品質チェック: この点数未満なら原因をログに残して再生成 (logs/quality_log.txt)
QUALITY_MIN_SCORE=80
QUALITY_MAX_RETRIES=2

# ===== YouTube =====
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
YOUTUBE_TOKEN_FILE=token.json
# 24 = エンターテインメント
YOUTUBE_CATEGORY_ID=24
# 即時投稿時の公開設定: public / unlisted / private
PRIVACY_STATUS=public
# 予約投稿の時刻 (topics.csv の date が未来日の場合に使用)
PUBLISH_TIME=19:00
TIMEZONE=Asia/Tokyo

# ===== X (旧 Twitter) =====
# https://developer.x.com でアプリを作成し、権限を「Read and write」にして発行。
# 4 つすべて設定すると platform=x のテーマを X に自動投稿する。
# ※ X API に予約投稿エンドポイントは無いため即時投稿になります。
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ===== Instagram (Graph API / リール) =====
# プロアカウント(ビジネス/クリエイター)+ 連携 Facebook ページ + 長期トークンが必要。
# 設定すると platform=instagram のテーマをリールとして自動投稿する。
# ※ Graph API に予約投稿エンドポイントは無いため即時公開になります。
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# リールをフィードにも表示する (true/false)
INSTAGRAM_SHARE_TO_FEED=true
# Graph API は公開 URL の動画しか取り込めない。videos/ を公開している場合は
# そのベース URL を設定する。未設定なら catbox.moe に一時アップロードする。
PUBLIC_MEDIA_BASE_URL=
